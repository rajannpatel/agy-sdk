{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Workshop: Open Check",
      "type": "shell",
      "command": "if ! command -v workshop >/dev/null 2>&1; then echo 'Workshop CLI is not installed or not on PATH.'; echo 'Install Workshop, then run: workshop launch agy-sdk'; exit 1; fi\nif ! workshop run agy-sdk -- doctor; then echo ''; echo 'Workshop is not ready for this checkout.'; echo 'Run: workshop launch agy-sdk'; echo 'If Workshop was already launched before recent SDK changes, run: workshop refresh agy-sdk'; exit 1; fi",
      "runOptions": {
        "runOn": "folderOpen"
      },
      "presentation": {
        "clear": true,
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
      "label": "Workshop: Launch",
      "type": "shell",
      "command": "workshop launch agy-sdk",
      "presentation": {
        "panel": "dedicated",
        "reveal": "always"
      },
      "problemMatcher": []
    },
    {
