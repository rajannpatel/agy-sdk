#!/usr/bin/env bash
# Wrapper script for Google Antigravity CLI (agy) inside Canonical Workshop.
# Automatically applies container-safe flags to run Chromium/browser components.
set -euo pipefail

ARGS=()
HAS_SANDBOX=false
HAS_NO_SANDBOX=false
HAS_UTILITY_FLAG=false
HAS_NONINTERACTIVE=false
COMMAND_TOKEN=""
IS_SUBCOMMAND=false
SKIP_NEXT=false

# Known subcommands that don't accept global flags like --no-sandbox
SUBCOMMANDS=(changelog help install models plugin plugins update)

VALUE_FLAGS=(
  --add-dir
  --conversation
  --log-file
  --model
  --print
  --print-timeout
  --prompt
  --prompt-interactive
  -i
  -p
)

# Non-interactive/print modes that don't launch the Electron TUI
NONINTERACTIVE_FLAGS=(
  --print
  --prompt
  --prompt-interactive
  -p
  -i
)

contains() {
  local needle=$1
  shift

  local item
  for item in "$@"; do
    [[ "$item" == "$needle" ]] && return 0
  done

  return 1
}

for arg in "$@"; do
  ARGS+=("$arg")

  if [[ "$SKIP_NEXT" == "true" ]]; then
    SKIP_NEXT=false
    continue
  fi

  case "$arg" in
    --sandbox)
      HAS_SANDBOX=true
      ;;
    --no-sandbox)
      HAS_NO_SANDBOX=true
      ;;
    -h|--help|--version)
      HAS_UTILITY_FLAG=true
      ;;
    --*=*)
      flag_name=${arg%%=*}
      if contains "$flag_name" "${NONINTERACTIVE_FLAGS[@]}"; then
        HAS_NONINTERACTIVE=true
      fi
      if contains "$flag_name" "${VALUE_FLAGS[@]}"; then
        continue
      fi
      ;;
    -*)
      if contains "$arg" "${NONINTERACTIVE_FLAGS[@]}"; then
        HAS_NONINTERACTIVE=true
      fi
      if contains "$arg" "${VALUE_FLAGS[@]}"; then
        SKIP_NEXT=true
      fi
      ;;
    *)
      if [[ -z "$COMMAND_TOKEN" ]]; then
        COMMAND_TOKEN=$arg
      fi
      ;;
  esac
done

if [[ -n "$COMMAND_TOKEN" ]] && contains "$COMMAND_TOKEN" "${SUBCOMMANDS[@]}"; then
  IS_SUBCOMMAND=true
fi

# For bare TUI invocations in a container/headless environment, Electron's
# Chromium subprocess needs --no-sandbox. Pass it via ELECTRON_EXTRA_LAUNCH_ARGS
# so it is picked up by Electron's process spawner rather than Go's flag.Parse(),
# which rejects unknown flags. Do not inject for subcommands, utility flags,
# explicit sandbox override, or non-interactive print/prompt modes.
if [[ "$HAS_SANDBOX" == "false" \
  && "$HAS_NO_SANDBOX" == "false" \
  && "$HAS_UTILITY_FLAG" == "false" \
  && "$HAS_NONINTERACTIVE" == "false" \
  && "$IS_SUBCOMMAND" == "false" ]]; then
  export ELECTRON_EXTRA_LAUNCH_ARGS="--no-sandbox${ELECTRON_EXTRA_LAUNCH_ARGS:+ $ELECTRON_EXTRA_LAUNCH_ARGS}"
fi

# Locate the actual binary (installed as agy-bin in the same bin directory)
REAL_AGY="$(dirname "$(readlink -f "$0")")/agy-bin"

exec "$REAL_AGY" "${ARGS[@]}"
