#!/usr/bin/env bash
# Wrapper script for Google Antigravity CLI (agy) inside Canonical Workshop.
# Automatically applies container-safe flags to run Chromium/browser components.

ARGS=()
HAS_SANDBOX=false
HAS_NO_SANDBOX=false
IS_SUBCOMMAND=false

# Known subcommands that don't accept global flags like --no-sandbox
SUBCOMMANDS=(changelog help install models plugin plugins update)

for arg in "$@"; do
  if [[ "$arg" == "--sandbox" ]]; then
    HAS_SANDBOX=true
  elif [[ "$arg" == "--no-sandbox" ]]; then
    HAS_NO_SANDBOX=true
  fi
  for sub in "${SUBCOMMANDS[@]}"; do
    if [[ "$arg" == "$sub" ]]; then
      IS_SUBCOMMAND=true
    fi
  done
  ARGS+=("$arg")
done

# Only inject --no-sandbox for interactive/non-interactive modes, not subcommands
if [[ "$HAS_SANDBOX" == "false" && "$HAS_NO_SANDBOX" == "false" && "$IS_SUBCOMMAND" == "false" ]]; then
  ARGS=("--no-sandbox" "${ARGS[@]}")
fi

# Locate the actual binary (installed as agy-bin in the same bin directory)
REAL_AGY="$(dirname "$(readlink -f "$0")")/agy-bin"

exec "$REAL_AGY" "${ARGS[@]}"
